#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONTROL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="${FKST_AEVATAR_ENV:-$CONTROL_ROOT/fkst-aevatar.env}"

if [ ! -f "$ENV_FILE" ]; then
  printf 'missing config: %s\n' "$ENV_FILE" >&2
  exit 1
fi

set -a
# shellcheck source=/dev/null
. "$ENV_FILE"
set +a

if [ -z "${AEVATAR_REPO:-}" ]; then
  printf 'AEVATAR_REPO is required in %s\n' "$ENV_FILE" >&2
  exit 1
fi
if [ -z "${FKST_INTEGRATION_BRANCH:-}" ]; then
  printf 'FKST_INTEGRATION_BRANCH is required in %s\n' "$ENV_FILE" >&2
  exit 1
fi

if ! git -C "$AEVATAR_REPO" diff --quiet || ! git -C "$AEVATAR_REPO" diff --cached --quiet; then
  printf 'refusing to sync with tracked Aevatar worktree changes: %s\n' "$AEVATAR_REPO" >&2
  git -C "$AEVATAR_REPO" status --short >&2
  exit 1
fi

if [ -n "$(git -C "$AEVATAR_REPO" ls-files --others --exclude-standard)" ]; then
  printf 'warning: untracked Aevatar files are present; sync will not use or remove them\n' >&2
  git -C "$AEVATAR_REPO" status --short >&2
fi

git -C "$AEVATAR_REPO" fetch origin dev "$FKST_INTEGRATION_BRANCH"

if git -C "$AEVATAR_REPO" show-ref --verify --quiet "refs/heads/$FKST_INTEGRATION_BRANCH"; then
  git -C "$AEVATAR_REPO" switch "$FKST_INTEGRATION_BRANCH"
  git -C "$AEVATAR_REPO" merge --ff-only "origin/$FKST_INTEGRATION_BRANCH"
else
  git -C "$AEVATAR_REPO" switch --track -c "$FKST_INTEGRATION_BRANCH" "origin/$FKST_INTEGRATION_BRANCH"
fi

git -C "$AEVATAR_REPO" merge --no-edit origin/dev
git -C "$AEVATAR_REPO" push origin "$FKST_INTEGRATION_BRANCH"

printf 'synced origin/dev into %s\n' "$FKST_INTEGRATION_BRANCH"
